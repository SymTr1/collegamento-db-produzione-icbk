# Connection string del database PostgreSQL di produzione
# Formato: postgresql://utente:password@host:porta/nome_database
DATABASE_URL=postgresql://user:password@host:25060/dbname?sslmode=require

# Imposta a "false" se il database non usa SSL (default: SSL attivo)
DATABASE_SSL=true

# API key per autenticare le richieste. Generane una sicura con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=your-secret-api-key-here
